{
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {},
    required: [],
    additionalProperties: false,
  },

  slots: {
    proxy: { kind: "a2a", optional: true },
  },

  program: {
    image: "ghcr.io/dirk61/mle_agent:latest",
    entrypoint: [
      "uv",
      "run",
      "src/server.py",
      "--host",
      "0.0.0.0",
      "--port",
      "9010"
    ],

    env: {
      ANTHROPIC_API_KEY: "${ANTHROPIC_API_KEY}",
    },

    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9010 },
      ],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: { a2a: "a2a" },
}
